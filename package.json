{
  "name": "ordermoto",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-s db:prepare dev:serve",
    "dev:client": "vite",
    "dev:serve": "run-p dev:server dev:client",
    "dev:server": "node server/server.mjs",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "start": "node server/server.mjs",
    "start:prod": "node server/start-production.mjs",
    "start:server": "node server/server.mjs",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "db:prepare": "run-s db:generate db:push",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.105.4",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^8.0.4",
    "prisma": "^6.19.3",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
